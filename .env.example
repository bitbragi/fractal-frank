# ── fractal-frank configuration ───────────────────────────────────────────────

# REQUIRED — UniSat OpenAPI key. Free: create one at the UniSat Developer Center
# https://developer.unisat.io  (a public API key, NOT a private key or seed —
# fractal-frank never handles private keys or seed phrases).
UNISAT_FRACTAL_API_KEY=your_unisat_fractal_api_key_here

# OPTIONAL — network selector: "mainnet" (default) or "testnet".
# Picks the UniSat OpenAPI base URL automatically; no host to set by hand.
FRACTAL_NETWORK=mainnet

# OPTIONAL (power-user) — a genuine Fractal Bitcoin Core JSON-RPC node endpoint.
# Only needed for node-only tools (broadcast, mempool, network/mining info,
# block-by-hash, script/tx decode, raw-tx build). Most read tools work on just
# the free key above — leave this blank if you don't run a node. Include
# basic-auth in the URL if your node needs it, e.g. http://user:pass@host:8332
FRACTAL_NODE_RPC_URL=
